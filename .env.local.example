# Overrides locais para desenvolvimento no Mac Studio.
# Copie para `.env.local` ou aplique os valores manualmente no seu `.env`.

CORS_ORIGIN=http://localhost:4310
NEXT_PUBLIC_API_BASE_URL=http://localhost:4311/api

# Se rodar a API local fora do Docker e o Postgres via compose:
POSTGRES_URL=postgresql://campaign_sender:change-me@127.0.0.1:5432/campaign_sender

# Segurança local: nunca deixe mutações de produção habilitadas por padrão.
APP_ENV=local
ALLOW_PROD_MUTATIONS=false
